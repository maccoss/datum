<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Datum.App.App"
             xmlns:local="using:Datum.App"
             RequestedThemeVariant="Light">
             <!-- Force the Light variant: the UI uses hardcoded light backgrounds (#f5f5f5, #e8eef5)
                  and gray text, so following a dark system theme ("Default") rendered theme-default
                  text white on those light panels (e.g. the sweep-results table on Windows dark mode).
                  "Default" follows the system; "Dark"/"Light" force a variant. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>